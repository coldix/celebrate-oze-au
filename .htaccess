# Cache policy (oze.au house standard)
# HTML: always revalidate. Versioned assets (?v=): 1-year immutable.
<IfModule mod_headers.c>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-store, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(css|js|webp|png|jpg|jpeg|gif|svg|ico|woff2?|json)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/plain
</IfModule>
